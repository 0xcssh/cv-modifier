{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "next build",
  "devCommand": "next dev",
  "installCommand": "npm install",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://cv-modifier-production.up.railway.app/api/:path*"
    }
  ],
  "crons": [
    {
      "path": "/cron/warmup",
      "schedule": "*/5 * * * *"
    }
  ]
}
